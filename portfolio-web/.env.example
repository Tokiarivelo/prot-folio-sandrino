# ─────────────────────────────────────────────
# Portfolio Web — Next.js Public Portfolio
# Copy to .env.local for local development
# ─────────────────────────────────────────────

# Backend API URL (used server-side in lib/api/ fetches)
# For local dev: http://localhost:3008
# For Docker:    http://backend:3008
# For production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3008

# Canonical site URL — used for SEO metadata and Open Graph
NEXT_PUBLIC_SITE_URL=http://localhost:4000
