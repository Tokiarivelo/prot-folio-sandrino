# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3008

# ─────────────────────────────────────────────
# Database (Supabase PostgreSQL)
# Use connection pooling URL for the app (PgBouncer compatible)
# Use the direct URL for Prisma migrations (prisma.config.ts)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────
# JWT Authentication
# Generate a strong secret: openssl rand -base64 32
# ─────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
JWT_EXPIRATION=7d

# ─────────────────────────────────────────────
# Supabase Storage
# Find these in: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-public-key>
SUPABASE_STORAGE_BUCKET=portfolio-media

# ─────────────────────────────────────────────
# Brevo (Transactional Email)
# API key: https://app.brevo.com/settings/keys/api
# SENDER_EMAIL must be a verified sender in your Brevo account
# ─────────────────────────────────────────────
BREVO_API_KEY=xkeysib-<your-api-key>
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Portfolio
BREVO_ADMIN_EMAIL=admin@yourdomain.com

# ─────────────────────────────────────────────
# CORS — comma-separated list of allowed frontend origins
# Include both the public portfolio and admin dashboard
# ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4000,http://localhost:4200

# ─────────────────────────────────────────────
# Seed (optional — used by prisma:seed script)
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@portfolio.dev
ADMIN_PASSWORD=Admin@123456
