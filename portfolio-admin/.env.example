# ─────────────────────────────────────────────
# Portfolio Admin — Angular Dashboard
# Copy to .env for local development
# ─────────────────────────────────────────────

# Port for the Angular dev server (ng serve)
PORT=4200

# NOTE: The API URL is configured at compile time in:
# src/environments/environment.ts        ← development
# src/environments/environment.prod.ts   ← production
#
# Change environment.ts to point to your backend URL.
# Default: http://localhost:3008
